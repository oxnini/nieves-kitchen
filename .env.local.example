NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile site key (public). Required for anonymous sign-ins
# now that Supabase enforces captcha. Get one at dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Set to "true" to use mock recipe data instead of Supabase (dev only)
NEXT_PUBLIC_USE_MOCK_DATA=
